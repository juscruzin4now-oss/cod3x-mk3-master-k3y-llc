# Codex MK3 local configuration example.
# Copy to .env for local use only. Never commit real secrets.

MK3_API_HOST=127.0.0.1
MK3_API_PORT=8080
MK3_API_BASE_URL=http://127.0.0.1:8080

# Optional manual Stripe balance check only.
# STRIPE_SECRET_KEY=sk_test_replace_me
# Optional Stripe test checkout. Use test-mode values only.
# STRIPE_TEST_PRICE_ID=price_test_replace_me
# STRIPE_SUCCESS_URL=http://127.0.0.1:8080/checkout/success
# STRIPE_CANCEL_URL=http://127.0.0.1:8080/checkout/cancel
